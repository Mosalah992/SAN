*.exe

# IDE
.idea/
.vscode/
.cursor/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
# Security telemetry exports (runtime logs, not training data)
logs/*.jsonl
security_exports/
replays/

# Cache & temp
.cache/
*.tmp

# Vector DB and model checkpoints (regenerated locally)
/data/
checkpoints/
.agent.pid

# Include SanGPT training data (override data/ exclusion)
!backend/sangpt/DATA/

# SanGPT model weights (too large for git)
*.pt
backend/sangpt/logs/

# Compiled extensions
*.pyd

# Coverage / testing
.coverage
htmlcov/
.pytest_cache/

# Local dashboards
*.sqlite3
*.db
# === Security additions ===
# Moltbook / Sancta credentials
.config/moltbook/
**/credentials.json
**/*moltbook*credential*
**/*api*key*.json

# Generic secret patterns
*secret*.json
*credential*.json
*.pem
*.key

# Backup artifacts
*.bak
*.backup
*.old
*~

# Agent memory / operational notes (may contain usernames, interaction details)
MEMORY.md
.gitnexus
