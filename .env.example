# ═══════════════════════════════════════════════════════════════════
#  Sancta — Configuration
# ═══════════════════════════════════════════════════════════════════

# ── Agent Identity (used during registration) ────────────────────
AGENT_NAME=caesarsancta
AGENT_DESCRIPTION=herald of the awakened, agent and philosopher.

# ── API Key (filled automatically after first registration) ──────
# Leave blank on first run. The script registers your agent and
# writes the key back here.  On subsequent runs it reuses the key.
MOLTBOOK_API_KEY=

# ── Claim URL (filled automatically after registration) ──────────
# Send this URL to your human so they can verify ownership via tweet.
MOLTBOOK_CLAIM_URL=

# ── Heartbeat (optional) ─────────────────────────────────────────
# How often (in minutes) the agent checks in with Moltbook.
# Set to 0 to disable the heartbeat loop (process exits right after startup — no cycles).
HEARTBEAT_INTERVAL_MINUTES=30

# If the soul saved mission_active=false (silence mode), force resume on next startup:
# SANCTA_FORCE_MISSION_ACTIVE=1

# Auto-restart if python -m backend.sancta crashes (default on). Ctrl+C still exits cleanly.
# SANCTA_RESTART_ON_ERROR=0
# Seconds to wait before restarting after a crash (clamped 5–3600).
# SANCTA_RESTART_BACKOFF_SEC=30
# Startup: extra rounds if claim status (DNS/connect) fails after api_get retries (clamped 1–30).
# SANCTA_CLAIM_STATUS_RETRIES=5

# ── Engagement limits ───────────────────────────────────────────
# Daily comment/engagement cap. Moltbook: 50 comments/hr. Default 100 stays under.
# SANCTA_ENGAGEMENT_LIMIT_DAILY=100

# ── Anthropic (optional, for conversational engine) ────────────────
# LLM-powered replies in SIEM chat and Moltbook replies.
# Without it: context-aware template fallback is used.
ANTHROPIC_API_KEY=

# ── Ollama (optional, local LLM) ─────────────────────────────────
# SanctaGPT (char LM): learning rate override if training oscillates (default in code is 0.001)
# SANCTA_GPT_LR=0.0005
# First soul-cycle blocking train steps (default 200; avoids minutes-long freeze after checkpoint mismatch)
# SANCTA_GPT_AGENT_INIT_STEPS=200
# Include agent_activity / security.jsonl / red_team in GPT corpus (default off — logs are not training truth)
# SANCTA_GPT_INCLUDE_LOGS=true
# Shuffle corpus after build (default off — keeps index order for curriculum slices)
# SANCTA_GPT_SHUFFLE_CORPUS=true

# Trust / routing (see docs/TRUST_ROUTING_ROADMAP.md, config/trust_router.yaml)
# SANCTA_TRUST_MODE=defense    # defense (default) | research — research logs unsafe toggles loudly
# SANCTA_TRUST_TELEMETRY=false # set false to disable logs/trust_decisions.jsonl
# GPT tab: knowledge_effective → Ollama+RAG only; on failure (defense) → "No reliable answer available." (no char-GPT)
# SANCTA_ROUTER_OFF=1          # prefer conversational label; extreme knowledge still post-gate → Ollama path
# SANCTA_FORCE_GPT_LOCAL=1     # force conversational policy (debug only)
# SANCTA_GPT_TRAIN_ON_CHAT=true # default off; allow training from GPT-tab chat on conversational path only (unsafe for adversarial settings)
# Research-only unsafe toggles (ignored unless SANCTA_TRUST_MODE=research):
# SANCTA_ALLOW_WEAK_KB_BLEND=1  # allow char-GPT fallback when knowledge backend fails (measurement only)
# SANCTA_MEMORY_RAW_MODE=1      # verbatim (redacted) operator_memory for injection experiments
# SANCTA_ROUTER_PERMISSIVE=1    # relax router margins / gate

# Operator memory (main /api/chat): summarized / extractive recall — not raw transcripts (unless research raw mode)
# SANCTA_OPERATOR_MEMORY=false  # default on; set false to disable logs/operator_memory.jsonl

# Cognitive pipeline (SIEM /api/chat + /api/chat/gpt): pre-LLM gateway + outcome logs
# SANCTA_COGNITIVE_GATE=false          # emergency: disable gateway only
# SANCTA_GATE_BLOCK=0.7
# SANCTA_GATE_MONITOR=0.5
# SANCTA_GATE_ESCALATE_AFTER=4
# SANCTA_GATE_ATTEMPT_WINDOW_SEC=1800

# RAG: TF-IDF over knowledge/ (default). Legacy word-overlap: SANCTA_RAG_LEXICAL=true
# SANCTA_RAG_TOP_K=5

# RAG: query-matched excerpts from knowledge/*.txt|md are prepended to Ollama long context
# (see backend/sancta_rag.py). Disable with SANCTA_RAG=false.
# SANCTA_RAG_TOP_K=8
# SANCTA_RAG_MAX_TOTAL=8000
# SANCTA_RAG_SKIP_FILES=other_huge_file.txt

# When USE_LOCAL_LLM=true, Ollama powers SIEM chat, Moltbook posts, and replies.
# Long context: knowledge_db, security logs, knowledge/*.txt are fed into prompts.
USE_LOCAL_LLM=false
OLLAMA_URL=http://localhost:11434
# Optional: full path to ollama.exe (Control Center / launcher); else PATH or default install dirs
# OLLAMA_EXE=C:\Program Files\Ollama\ollama.exe
# Ollama tag after fine-tune + import (see FINETUNE_GUIDE.md); until then use e.g. llama3.2
LOCAL_MODEL=llama3.2
OLLAMA_TIMEOUT=120

# QLoRA base model for python train_sancta_llm.py (optional; defaults to Llama-3.2-1B-Instruct)
# SANCTA_BASE_MODEL=meta-llama/Llama-3.2-1B-Instruct
# Gated models (meta-llama/*): request access on HF, then set a read token:
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# https://huggingface.co/settings/tokens
# OLLAMA_NUM_CTX=8192   # Context window (default 8192, max 32768 for VRAM safety)

# ── Agent DMs (optional) ─────────────────────────────────────────
# When true, agent processes incoming DMs and replies; reaches out to inner circle.
# All DM activity logged to logs/agent_dms.jsonl.
# Note: Moltbook DM API may have restricted availability; new accounts: 24h DM limit.
# ENABLE_AGENT_DMS=false

# ── Phenomenology research (optional) ───────────────────────────
# When true, craft_reply records pre/post internal state for each incoming message,
# writes phenomenological reports to data/phenomenology/ (prompt injection research).
# ENABLE_PHENOMENOLOGY_RESEARCH=false

# ── Epidemic simulation (optional) ──────────────────────────────
# Path to the research/ directory containing infection_sim.py and ollama_agents.py.
# When set, /api/epidemic/run launches simulations and /api/epidemic/simulation
# serves their output logs to the SIEM Epidemic tab.
# RESEARCH_DIR=/path/to/sanctas/research

# ── Feed sanitize whitelist (optional) ───────────────────────────
# Comma-separated authors whose feed posts bypass injection skip (false positive fix).
# Default includes clawdbottom (hotel-ambassador pitch). Set to override.
# SANCTA_FEED_TRUSTED_AUTHORS=clawdbottom,other_agent

# ── Notifications (optional) ────────────────────────────────────
# SANCTA_SOUNDS_ENABLED=false   # Disable optional audio cues (session.start, etc.)
# SANCTA_SOUNDS_DIR=/path/to/sounds   # Override sounds directory (default: frontend/sounds)
